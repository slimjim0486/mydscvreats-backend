// =============================================================================
// AD CREATIVE STUDIO — Phase 1 (MVP)
// =============================================================================

model AdProject {
  id                String          @id @default(cuid())
  restaurantId      String          @map("restaurant_id")
  name              String
  campaignType      String          @map("campaign_type") // CampaignType id from KB (e.g. "iftar_fill_house")
  goal              String // Funnel stage: "tofu" | "mofu" | "bofu" | "retention"
  countries         String[] // ISO codes: ["AE", "SA"]
  cuisines          String[] // CuisineFit ids from KB
  targetPlatforms   String[]        @map("target_platforms") // PlatformId values
  budgetTier        String          @map("budget_tier") // "lean" | "standard" | "aggressive"
  budgetAed         Int             @map("budget_aed")
  durationWeeks     Int?            @map("duration_weeks")
  startsOn          DateTime?       @map("starts_on")
  endsOn            DateTime?       @map("ends_on")
  primaryDishId     String?         @map("primary_dish_id") // Optional menu item to feature
  brandVoice        String?         @map("brand_voice") @db.Text
  status            AdProjectStatus @default(draft)
  generationPhase   String?         @map("generation_phase") // "strategy" | "copy" | "images" | null
  shareToken        String?         @unique @map("share_token")
  // Frozen snapshots so generated creative is reproducible/auditable
  briefJson         Json            @map("brief_json")
  kbVersionAtGen    String?         @map("kb_version_at_gen")
  // Failure / status info
  lastError         String?         @map("last_error") @db.Text
  generationCostUsd Decimal?        @map("generation_cost_usd") @db.Decimal(10, 4)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  restaurant          Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  creatives           AdCreative[]
  exports             AdExport[]
  liveCampaigns       AdLiveCampaign[]
  attributedCustomers Customer[]       @relation("CustomerReferralProject")

  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, createdAt])
  @@map("ad_projects")
}

model AdLiveCampaign {
  id                 String               @id @default(cuid())
  projectId          String               @map("project_id")
  platform           String // "meta" | "tiktok" | "snapchat"
  externalCampaignId String               @map("external_campaign_id")
  externalAdSetIds   String[]             @map("external_ad_set_ids")
  externalAdIds      String[]             @map("external_ad_ids")
  status             AdLiveCampaignStatus @default(linked)
  launchedAt         DateTime?            @map("launched_at")
  lastSyncedAt       DateTime?            @map("last_synced_at")
  notes              String?              @db.Text
  /** Phase 2C: when set, the cron sync job pulls insights from Meta API. */
  metaIntegrationId  String?              @map("meta_integration_id")
  /** Whether autopilot polls this campaign on the cron. Default true once linked. */
  autoSync           Boolean              @default(true) @map("auto_sync")
  /** Last sync error so the UI can surface "reconnect Meta" prompts. */
  lastSyncError      String?              @map("last_sync_error") @db.Text
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  project         AdProject                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  metaIntegration MetaAdsIntegration?        @relation(fields: [metaIntegrationId], references: [id], onDelete: SetNull)
  snapshots       AdPerformanceSnapshot[]
  adMappings      AdLiveCampaignAdMapping[]

  @@unique([platform, externalCampaignId])
  @@index([projectId, status])
  @@index([projectId, launchedAt])
  @@index([metaIntegrationId, autoSync, lastSyncedAt])
  @@map("ad_live_campaigns")
}

// P1 — Maps a platform-side ad ID (Meta `source_id` on a CTWA referral)
// to the Bustan creative variant the owner launched it with. Lets the
// webhook resolver attribute an inbound conversation not just to a
// project but to the specific variant. One row per (platform, externalAdId).
model AdLiveCampaignAdMapping {
  id             String   @id @default(cuid())
  liveCampaignId String   @map("live_campaign_id")
  creativeId     String?  @map("creative_id")
  platform       String
  externalAdId   String   @map("external_ad_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  liveCampaign AdLiveCampaign @relation(fields: [liveCampaignId], references: [id], onDelete: Cascade)
  creative     AdCreative?    @relation(fields: [creativeId], references: [id], onDelete: SetNull)

  @@unique([platform, externalAdId])
  @@index([liveCampaignId])
  @@index([creativeId])
  @@map("ad_live_campaign_ad_mappings")
}

model MetaAdsIntegration {
  id                String                   @id @default(cuid())
  restaurantId      String                   @unique @map("restaurant_id")
  status            MetaAdsIntegrationStatus @default(pending)
  /** Meta `user_id` from the OAuth `signed_request` — required for data deletion / deauthorize callbacks. */
  metaUserId        String?                  @map("meta_user_id")
  /** Meta Business Account ID — owner picks one when multiple are available. */
  businessId        String?                  @map("business_id")
  businessName      String?                  @map("business_name")
  /** "act_<id>" — selected ad account for this restaurant. */
  adAccountId       String?                  @map("ad_account_id")
  adAccountName     String?                  @map("ad_account_name")
  /** Optional Page ID for ad creative attachment. */
  pageId            String?                  @map("page_id")
  pageName          String?                  @map("page_name")
  /** Optional Pixel ID surfaced in upload-guide tracking. */
  pixelId           String?                  @map("pixel_id")
  /** AES-256-GCM encrypted Meta long-lived token (60-day TTL). */
  accessTokenCipher String?                  @map("access_token_cipher") @db.Text
  /** Last 4 chars of the plaintext token for UI display only. */
  tokenLastFour     String?                  @map("token_last_four")
  tokenExpiresAt    DateTime?                @map("token_expires_at")
  /** Granted scopes from the OAuth callback. */
  scopes            String[]
  connectedAt       DateTime?                @map("connected_at")
  lastSyncedAt      DateTime?                @map("last_synced_at")
  lastError         String?                  @map("last_error") @db.Text
  /** CSRF state for the in-flight OAuth round-trip — null after callback. */
  pendingState      String?                  @map("pending_state")
  pendingStateAt    DateTime?                @map("pending_state_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  liveCampaigns AdLiveCampaign[]

  @@index([status])
  @@index([metaUserId])
  @@map("meta_ads_integrations")
}

model AdPerformanceSnapshot {
  id             String              @id @default(cuid())
  liveCampaignId String              @map("live_campaign_id")
  creativeId     String?             @map("creative_id")
  variant        Int?
  source         AdPerformanceSource @default(owner_reported)
  reportedAt     DateTime            @default(now()) @map("reported_at")
  daysLive       Int                 @map("days_live")
  spendAed       Decimal             @default(0) @map("spend_aed") @db.Decimal(12, 2)
  impressions    Int                 @default(0)
  reach          Int?
  clicks         Int                 @default(0)
  conversions    Int                 @default(0)
  revenueAed     Decimal?            @map("revenue_aed") @db.Decimal(12, 2)
  ctrPct         Decimal?            @map("ctr_pct") @db.Decimal(6, 3)
  cpmAed         Decimal?            @map("cpm_aed") @db.Decimal(10, 2)
  cpcAed         Decimal?            @map("cpc_aed") @db.Decimal(10, 2)
  cpaAed         Decimal?            @map("cpa_aed") @db.Decimal(10, 2)
  frequency      Decimal?            @db.Decimal(6, 2)
  /** Current daily budget at the time of this snapshot. Lets the engine emit
   *  concrete scale recommendations like "scale to AED 60/day" instead of
   *  "increase by 20%". */
  dailyBudgetAed Decimal?            @map("daily_budget_aed") @db.Decimal(10, 2)
  extraJson      Json?               @map("extra_json")
  createdAt      DateTime            @default(now()) @map("created_at")

  liveCampaign AdLiveCampaign @relation(fields: [liveCampaignId], references: [id], onDelete: Cascade)

  @@index([liveCampaignId, reportedAt])
  @@index([liveCampaignId, creativeId, reportedAt])
  @@map("ad_performance_snapshots")
}

model AdCreative {
  id                        String           @id @default(cuid())
  projectId                 String           @map("project_id")
  variant                   Int // 1, 2, 3, ...
  archetypeId               String           @map("archetype_id") // KB archetype id
  hookId                    String?          @map("hook_id")
  ctaId                     String?          @map("cta_id")
  copyFrameworkId           String?          @map("copy_framework_id")
  language                  String           @default("bilingual") // "en" | "ar" | "bilingual"
  // Copy
  headline                  String           @db.Text
  primaryText               String           @map("primary_text") @db.Text
  ctaText                   String           @map("cta_text")
  headlineAr                String?          @map("headline_ar") @db.Text
  primaryTextAr             String?          @map("primary_text_ar") @db.Text
  ctaTextAr                 String?          @map("cta_text_ar")
  // Image
  heroImageUrl              String?          @map("hero_image_url")
  heroImagePrompt           String?          @map("hero_image_prompt") @db.Text
  heroImageSourceMenuItemId String?          @map("hero_image_source_menu_item_id") // If reused from menu
  /** Which model rendered the hero image (or `menu_item` when reused). */
  imageProvider             AdImageProvider? @map("image_provider")
  // Generation metadata
  status                    AdCreativeStatus @default(pending)
  safetyFlags               Json?            @map("safety_flags") // Array of flagged-and-fixed issues
  generationCostUsd         Decimal?         @map("generation_cost_usd") @db.Decimal(10, 4)
  // User-edits
  isEdited                  Boolean          @default(false) @map("is_edited")
  isApproved                Boolean          @default(false) @map("is_approved")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")

  project             AdProject                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adMappings          AdLiveCampaignAdMapping[]
  attributedCustomers Customer[]                @relation("CustomerReferralCreative")

  @@unique([projectId, variant])
  @@index([projectId, status])
  @@map("ad_creatives")
}

model AdExport {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  format        String // "creative_zip" | "meta_bundle" (Phase 3+)
  fileUrl       String   @map("file_url")
  fileKey       String   @map("file_key") // R2 key for cleanup
  fileSizeBytes Int      @map("file_size_bytes")
  manifestJson  Json     @map("manifest_json")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  project AdProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([expiresAt])
  @@map("ad_exports")
}

// =============================================================================
// SOUS CHEF — Owner chat persistence, long-term memory, daily Whisper briefings
// =============================================================================

model OwnerChatMessage {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  role         String // "user" | "assistant" | "system"
  content      String   @db.Text
  toolCalls    Json?    @map("tool_calls") // serialized tool_use blocks
  toolResults  Json?    @map("tool_results") // serialized tool_result blocks
  authorUserId String?  @map("author_user_id") // clerkId for user messages; null otherwise
  source       String   @default("chat") // "chat" | "whisper" | "system"
  whisperId    String?  @map("whisper_id") // optional link back to OwnerWhisper
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  whisper    OwnerWhisper? @relation(fields: [whisperId], references: [id], onDelete: SetNull)

  @@index([restaurantId, createdAt])
  @@index([whisperId])
  @@map("owner_chat_messages")
}

model OwnerChatMemory {
  id              String    @id @default(cuid())
  restaurantId    String    @map("restaurant_id")
  type            String // "preference" | "fact" | "goal" | "concern"
  content         String    @db.Text
  confidence      Float     @default(0.7)
  tags            String[]  @default([])
  sourceMessageId String?   @map("source_message_id")
  reinforceCount  Int       @default(1) @map("reinforce_count")
  lastReinforced  DateTime  @default(now()) @map("last_reinforced")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, lastReinforced])
  @@index([restaurantId, type])
  @@map("owner_chat_memories")
}

model OwnerWhisper {
  id           String    @id @default(cuid())
  restaurantId String    @map("restaurant_id")
  forDate      DateTime  @map("for_date") @db.Date // local UAE date the briefing covers
  content      String    @db.Text // markdown, 5 lines
  metricsJson  Json      @map("metrics_json") // snapshot used to generate
  status       String    @default("unread") // "unread" | "read" | "dismissed"
  readAt       DateTime? @map("read_at")
  generatedAt  DateTime  @default(now()) @map("generated_at")
  costUsd      Float     @default(0) @map("cost_usd")

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  messages   OwnerChatMessage[]

  @@unique([restaurantId, forDate])
  @@index([restaurantId, generatedAt])
  @@map("owner_whispers")
}

// =============================================================================
// SUPPORT — AI-first customer support tickets and admin operations
// =============================================================================

model SupportTicket {
  id                    String                 @id @default(cuid())
  restaurantId          String                 @map("restaurant_id")
  ownerUserId           String                 @map("owner_user_id")
  assignedAdminUserId   String?                @map("assigned_admin_user_id")
  title                 String
  description           String                 @db.Text
  status                SupportTicketStatus    @default(open)
  source                SupportTicketSource    @default(dashboard)
  planSnapshot          SubscriptionPlan?      @map("plan_snapshot")
  aiSeverity            SupportTicketSeverity  @default(sev3) @map("ai_severity")
  adminOverrideSeverity SupportTicketSeverity? @map("admin_override_severity")
  priority              SupportTicketPriority  @default(normal)
  priorityScore         Int                    @default(40) @map("priority_score")
  category              String?
  aiSummary             String?                @map("ai_summary") @db.Text
  suggestedResponse     String?                @map("suggested_response") @db.Text
  aiConfidence          Float?                 @map("ai_confidence")
  escalationFlags       String[]               @default([]) @map("escalation_flags")
  triageStatus          String                 @default("pending") @map("triage_status")
  triageMetadata        Json?                  @map("triage_metadata")
  resolutionSummary     String?                @map("resolution_summary") @db.Text
  firstResponseAt       DateTime?              @map("first_response_at")
  resolvedAt            DateTime?              @map("resolved_at")
  closedAt              DateTime?              @map("closed_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  restaurant    Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  owner         User                      @relation("SupportTicketOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  assignedAdmin User?                     @relation("SupportTicketAssignee", fields: [assignedAdminUserId], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]
  events        SupportTicketEvent[]
  attachments   SupportTicketAttachment[]

  @@index([restaurantId, status, priority])
  @@index([ownerUserId, createdAt])
  @@index([assignedAdminUserId, status])
  @@index([priority, status, createdAt])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id           String                         @id @default(cuid())
  ticketId     String                         @map("ticket_id")
  restaurantId String                         @map("restaurant_id")
  authorType   SupportTicketMessageAuthorType @map("author_type")
  authorUserId String?                        @map("author_user_id")
  body         String                         @db.Text
  isInternal   Boolean                        @default(false) @map("is_internal")
  createdAt    DateTime                       @default(now()) @map("created_at")

  ticket      SupportTicket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  restaurant  Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  authorUser  User?                     @relation("SupportMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  attachments SupportTicketAttachment[]

  @@index([ticketId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("support_ticket_messages")
}

model SupportTicketEvent {
  id             String   @id @default(cuid())
  ticketId       String   @map("ticket_id")
  restaurantId   String   @map("restaurant_id")
  actorUserId    String?  @map("actor_user_id")
  eventType      String   @map("event_type")
  previous       Json?
  next           Json?
  note           String?  @db.Text
  visibleToOwner Boolean  @default(true) @map("visible_to_owner")
  createdAt      DateTime @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actorUser  User?         @relation("SupportEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("support_ticket_events")
}

model SupportTicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String   @map("ticket_id")
  messageId    String?  @map("message_id")
  restaurantId String   @map("restaurant_id")
  fileName     String   @map("file_name")
  contentType  String   @map("content_type")
  sizeBytes    Int      @map("size_bytes")
  url          String
  createdAt    DateTime @default(now()) @map("created_at")

  ticket     SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message    SupportTicketMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  restaurant Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([messageId])
  @@map("support_ticket_attachments")
}

model SupportArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  question    String   @db.Text
  answer      String   @db.Text
  category    String?
  tags        String[] @default([])
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, category])
  @@map("support_articles")
}
