generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  restaurant_owner
  admin
}

enum SubscriptionStatus {
  trial
  active
  paused
  cancelled
}

enum SubscriptionPlan {
  starter
  pro
  portfolio
}

enum DomainStatus {
  pending
  verifying
  active
  failed
}

enum GbpConnectionStatus {
  not_connected
  self_reported
  verified
}

enum SeoStatus {
  queued
  running
  succeeded
  failed
}

enum PromotionType {
  discounted_item
  deal
  combo
}

enum MenuItemImageOrigin {
  legacy_unspecified
  bustan_ai
  owner_upload
  menu_source_upload
}

enum MenuItemImageDerivation {
  original
  truth_preserving_edit
  synthetic_generation
}

enum MenuSourceImageReviewStatus {
  pending
  confirmed
  dismissed
}

enum CustomerConsentStatus {
  opt_in
  opt_out
}

enum OrderFulfillmentMethod {
  delivery
  pickup
}

enum OrderIntentStatus {
  sent_to_whatsapp
  opened_whatsapp
}

enum CampaignType {
  inactive_30
  weekend_special
  new_promotion
}

enum CampaignStatus {
  draft
  logged
  sending
  sent
  failed
}

enum MessageLogStatus {
  logged
  skipped_opt_out
  queued
  sent
  delivered
  read
  failed
}

enum WhatsAppIntegrationStatus {
  pending
  connected
  needs_review
  failed
  disconnected
}

enum WhatsAppTemplateStatus {
  draft
  pending
  approved
  rejected
  paused
  disabled
}

enum WhatsAppMessageDirection {
  inbound
  outbound
}

enum WhatsAppMessageType {
  text
  image
  audio
  video
  document
  button
  interactive
  template
  unknown
}

enum WhatsAppMessageStatus {
  received
  queued
  sent
  delivered
  read
  failed
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  fullName  String?  @map("full_name")
  role      UserRole @default(restaurant_owner)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurants     Restaurant[]
  operatorAccount OperatorAccount?

  @@map("users")
}

model Restaurant {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  description        String?
  cuisineType        String?            @map("cuisine_type")
  themeKey           String?            @map("theme_key")
  location           String?
  address            String?
  phone              String?
  website            String?
  whatsappNumber     String?            @map("whatsapp_number")
  whatsappPrefill    String?            @map("whatsapp_prefill")
  deliverooUrl       String?            @map("deliveroo_url")
  talabatUrl         String?            @map("talabat_url")
  uberEatsUrl        String?            @map("uber_eats_url")
  operatingHours     Json?              @map("operating_hours")
  logoUrl            String?            @map("logo_url")
  coverImageUrl      String?            @map("cover_image_url")
  isPublished        Boolean            @default(false) @map("is_published")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  ownerId            String             @map("owner_user_id")
  operatorAccountId  String?            @map("operator_account_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  owner                     User                       @relation(fields: [ownerId], references: [id])
  operatorAccount           OperatorAccount?           @relation(fields: [operatorAccountId], references: [id], onDelete: SetNull)
  menuSections              MenuSection[]
  menuItems                 MenuItem[]
  subscription              Subscription?
  customDomain              RestaurantDomain?
  shortLink                 RestaurantShortLink?
  pageViews                 PageView[]
  brandingClicks            BrandingClick[]
  shortLinkClicks           RestaurantShortLinkClick[]
  whatsappClicks            WhatsAppClick[]
  whatsappCartOrders        WhatsAppCartOrder[]
  customers                 Customer[]
  customerConsents          CustomerConsent[]
  orderIntents              OrderIntent[]
  campaigns                 Campaign[]
  messageLogs               MessageLog[]
  whatsappIntegration       WhatsAppIntegration?
  whatsappTemplates         WhatsAppTemplate[]
  whatsappConversations     WhatsAppConversation[]
  whatsappMessages          WhatsAppMessage[]
  whatsappStatusEvents      WhatsAppMessageStatusEvent[]
  menuItemLikes             MenuItemLike[]
  menuSourceImageCandidates MenuSourceImageCandidate[]
  slugAliases               RestaurantSlugAlias[]
  promotions                Promotion[]
  gbpConnection             GbpConnection?
  seoAnalyses               SeoAnalysis[]

  @@index([ownerId])
  @@index([operatorAccountId])
  @@map("restaurants")
}

model MenuSection {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  name         String
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([restaurantId, displayOrder])
  @@map("menu_sections")
}

model MenuItem {
  id                  String    @id @default(cuid())
  sectionId           String    @map("section_id")
  restaurantId        String    @map("restaurant_id")
  name                String
  description         String?
  aiNotes             String?   @map("ai_notes")
  price               Decimal   @db.Decimal(10, 2)
  currency            String    @default("AED")
  imageUrl            String?   @map("image_url")
  imageStatus         String    @default("none") @map("image_status")
  isAvailable         Boolean   @default(true) @map("is_available")
  soldOutDate         DateTime? @map("sold_out_date") @db.Date
  specialStartsAt     DateTime? @map("special_starts_at")
  specialEndsAt       DateTime? @map("special_ends_at")
  displayOrder        Int       @default(0) @map("display_order")
  aiDescriptionStatus String?   @map("ai_description_status")
  originalDescription String?   @map("original_description")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  section                   MenuSection                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  restaurant                Restaurant                 @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  images                    MenuItemImage[]
  dietaryTags               MenuItemDietaryTag[]
  badges                    MenuItemBadge[]
  promotionItems            PromotionItem[]
  whatsappClicks            WhatsAppClick[]
  whatsappCartOrderItems    WhatsAppCartOrderItem[]
  orderIntentItems          OrderIntentItem[]
  likes                     MenuItemLike[]
  suggestedMenuSourceImages MenuSourceImageCandidate[] @relation("SuggestedMenuSourceImageCandidate")
  assignedMenuSourceImages  MenuSourceImageCandidate[] @relation("AssignedMenuSourceImageCandidate")

  @@index([restaurantId, displayOrder])
  @@index([sectionId, displayOrder])
  @@map("menu_items")
}

model MenuItemImage {
  id             String                  @id @default(cuid())
  menuItemId     String                  @map("menu_item_id")
  slot           Int
  imageUrl       String?                 @map("image_url")
  imageStatus    String                  @default("none") @map("image_status")
  promptModifier String?                 @map("prompt_modifier")
  isPrimary      Boolean                 @default(false) @map("is_primary")
  originType     MenuItemImageOrigin     @default(legacy_unspecified) @map("origin_type")
  derivationType MenuItemImageDerivation @default(original) @map("derivation_type")
  parentImageId  String?                 @map("parent_image_id")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  menuItem         MenuItem                   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  parentImage      MenuItemImage?             @relation("MenuItemImageDerivation", fields: [parentImageId], references: [id], onDelete: SetNull)
  derivedImages    MenuItemImage[]            @relation("MenuItemImageDerivation")
  sourceCandidates MenuSourceImageCandidate[]

  @@unique([menuItemId, slot])
  @@index([menuItemId, createdAt])
  @@index([parentImageId])
  @@map("menu_item_images")
}

model MenuSourceImageCandidate {
  id                  String                      @id @default(cuid())
  restaurantId        String                      @map("restaurant_id")
  imageUrl            String                      @map("image_url")
  sourcePageImageUrl  String?                     @map("source_page_image_url")
  sourcePageNumber    Int                         @map("source_page_number")
  cropX               Float?                      @map("crop_x")
  cropY               Float?                      @map("crop_y")
  cropWidth           Float?                      @map("crop_width")
  cropHeight          Float?                      @map("crop_height")
  textOverlapScore    Float?                      @map("text_overlap_score")
  confidence          Float
  note                String?
  reviewStatus        MenuSourceImageReviewStatus @default(pending) @map("review_status")
  suggestedMenuItemId String?                     @map("suggested_menu_item_id")
  assignedMenuItemId  String?                     @map("assigned_menu_item_id")
  linkedImageId       String?                     @map("linked_image_id")
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")

  restaurant        Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  suggestedMenuItem MenuItem?      @relation("SuggestedMenuSourceImageCandidate", fields: [suggestedMenuItemId], references: [id], onDelete: SetNull)
  assignedMenuItem  MenuItem?      @relation("AssignedMenuSourceImageCandidate", fields: [assignedMenuItemId], references: [id], onDelete: SetNull)
  linkedImage       MenuItemImage? @relation(fields: [linkedImageId], references: [id], onDelete: SetNull)

  @@index([restaurantId, reviewStatus, createdAt])
  @@index([suggestedMenuItemId])
  @@index([assignedMenuItemId])
  @@index([linkedImageId])
  @@map("menu_source_image_candidates")
}

model Promotion {
  id           String        @id @default(cuid())
  restaurantId String        @map("restaurant_id")
  type         PromotionType
  title        String
  subtitle     String?
  description  String?
  badgeLabel   String?       @map("badge_label")
  terms        String?
  promoPrice   Decimal?      @map("promo_price") @db.Decimal(10, 2)
  startsAt     DateTime?     @map("starts_at")
  endsAt       DateTime?     @map("ends_at")
  isActive     Boolean       @default(true) @map("is_active")
  isFeatured   Boolean       @default(true) @map("is_featured")
  displayOrder Int           @default(0) @map("display_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items          PromotionItem[]
  whatsappClicks WhatsAppClick[]
  campaigns      Campaign[]

  @@index([restaurantId, displayOrder])
  @@index([restaurantId, isActive, startsAt, endsAt])
  @@map("promotions")
}

model PromotionItem {
  id           String   @id @default(cuid())
  promotionId  String   @map("promotion_id")
  menuItemId   String   @map("menu_item_id")
  role         String   @default("included")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([promotionId, menuItemId])
  @@index([menuItemId, displayOrder])
  @@index([promotionId, displayOrder])
  @@map("promotion_items")
}

model Subscription {
  id                   String             @id @default(cuid())
  restaurantId         String             @unique @map("restaurant_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

model OperatorAccount {
  id                   String             @id @default(cuid())
  name                 String
  ownerId              String             @unique @map("owner_user_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  status               SubscriptionStatus @default(trial)
  brandLimit           Int                @default(10) @map("brand_limit")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  owner  User         @relation(fields: [ownerId], references: [id])
  brands Restaurant[]

  @@index([status])
  @@map("operator_accounts")
}

model MenuCloneLog {
  id                 String   @id @default(cuid())
  sourceRestaurantId String   @map("source_restaurant_id")
  targetRestaurantId String   @map("target_restaurant_id")
  cloneType          String
  sourceSectionId    String?  @map("source_section_id")
  itemsCopied        Int      @default(0) @map("items_copied")
  sectionsCopied     Int      @default(0) @map("sections_copied")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([sourceRestaurantId, createdAt])
  @@index([targetRestaurantId, createdAt])
  @@map("menu_clone_logs")
}

model PageView {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  path         String
  hostname     String?
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("page_views")
}

model BrandingClick {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  path         String?
  referrer     String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("branding_clicks")
}

model MenuItemLike {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  menuItemId   String   @map("menu_item_id")
  path         String?
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
  @@map("menu_item_likes")
}

model WhatsAppClick {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  menuItemId   String?  @map("menu_item_id")
  promotionId  String?  @map("promotion_id")
  source       String
  path         String?
  campaign     String?
  referrer     String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem    MenuItem?          @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  promotion   Promotion?         @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  cartOrder   WhatsAppCartOrder?
  orderIntent OrderIntent?

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
  @@index([promotionId, createdAt])
  @@map("whatsapp_clicks")
}

model WhatsAppCartOrder {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  clickId      String   @unique @map("click_id")
  totalPrice   Decimal  @map("total_price") @db.Decimal(10, 2)
  currency     String   @default("AED")
  itemCount    Int      @map("item_count")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  click      WhatsAppClick           @relation(fields: [clickId], references: [id], onDelete: Cascade)
  items      WhatsAppCartOrderItem[]

  @@index([restaurantId, createdAt])
  @@map("whatsapp_cart_orders")
}

model WhatsAppCartOrderItem {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  menuItemId String?  @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  order    WhatsAppCartOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem?         @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([menuItemId])
  @@map("whatsapp_cart_order_items")
}

model Customer {
  id                String    @id @default(cuid())
  restaurantId      String    @map("restaurant_id")
  normalizedPhone   String    @map("normalized_phone")
  phoneNumber       String    @map("phone_number")
  displayName       String    @map("display_name")
  marketingOptIn    Boolean   @default(false) @map("marketing_opt_in")
  marketingOptInAt  DateTime? @map("marketing_opt_in_at")
  marketingOptOutAt DateTime? @map("marketing_opt_out_at")
  lastOrderAt       DateTime? @map("last_order_at")
  orderCount        Int       @default(0) @map("order_count")
  totalSpend        Decimal   @default(0) @map("total_spend") @db.Decimal(10, 2)
  currency          String    @default("AED")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  consents   CustomerConsent[]
  orders     OrderIntent[]
  messages   MessageLog[]
  whatsappConversations WhatsAppConversation[]
  whatsappMessages      WhatsAppMessage[]

  @@unique([restaurantId, normalizedPhone])
  @@index([restaurantId, marketingOptIn])
  @@index([restaurantId, lastOrderAt])
  @@map("customers")
}

model CustomerConsent {
  id           String                @id @default(cuid())
  restaurantId String                @map("restaurant_id")
  customerId   String                @map("customer_id")
  status       CustomerConsentStatus
  channel      String                @default("whatsapp")
  source       String
  ipAddress    String?               @map("ip_address")
  userAgent    String?               @map("user_agent")
  createdAt    DateTime              @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([customerId, createdAt])
  @@map("customer_consents")
}

model OrderIntent {
  id                String                 @id @default(cuid())
  restaurantId      String                 @map("restaurant_id")
  customerId        String?                @map("customer_id")
  clickId           String?                @unique @map("click_id")
  status            OrderIntentStatus      @default(sent_to_whatsapp)
  fulfillmentMethod OrderFulfillmentMethod @map("fulfillment_method")
  customerName      String                 @map("customer_name")
  phoneNumber       String                 @map("phone_number")
  address           String?
  notes             String?
  totalPrice        Decimal                @map("total_price") @db.Decimal(10, 2)
  currency          String                 @default("AED")
  itemCount         Int                    @map("item_count")
  sourcePath        String?                @map("source_path")
  campaign          String?
  createdAt         DateTime               @default(now()) @map("created_at")

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  click      WhatsAppClick?    @relation(fields: [clickId], references: [id], onDelete: SetNull)
  items      OrderIntentItem[]

  @@index([restaurantId, createdAt])
  @@index([customerId, createdAt])
  @@map("order_intents")
}

model OrderIntentItem {
  id            String   @id @default(cuid())
  orderIntentId String   @map("order_intent_id")
  menuItemId    String?  @map("menu_item_id")
  itemName      String   @map("item_name")
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  orderIntent OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)
  menuItem    MenuItem?   @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderIntentId])
  @@index([menuItemId])
  @@map("order_intent_items")
}

model Campaign {
  id            String         @id @default(cuid())
  restaurantId  String         @map("restaurant_id")
  promotionId   String?        @map("promotion_id")
  type          CampaignType
  status        CampaignStatus @default(draft)
  name          String
  templateName  String         @map("template_name")
  body          String
  targetSegment String         @map("target_segment")
  targetCount   Int            @default(0) @map("target_count")
  loggedCount   Int            @default(0) @map("logged_count")
  createdAt     DateTime       @default(now()) @map("created_at")
  loggedAt      DateTime?      @map("logged_at")

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  promotion  Promotion?   @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  messages   MessageLog[]

  @@index([restaurantId, createdAt])
  @@index([promotionId])
  @@map("campaigns")
}

model MessageLog {
  id           String           @id @default(cuid())
  restaurantId String           @map("restaurant_id")
  customerId   String?          @map("customer_id")
  campaignId   String?          @map("campaign_id")
  channel      String           @default("whatsapp")
  direction    String           @default("outbound")
  status       MessageLogStatus @default(logged)
  body         String
  whatsappUrl  String?          @map("whatsapp_url")
  templateName String?          @map("template_name")
  providerMessageId String?     @unique @map("provider_message_id")
  errorCode    String?          @map("error_code")
  errorMessage String?          @map("error_message")
  sentAt       DateTime?        @map("sent_at")
  deliveredAt  DateTime?        @map("delivered_at")
  readAt       DateTime?        @map("read_at")
  failedAt     DateTime?        @map("failed_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  campaign   Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  whatsappMessage WhatsAppMessage?

  @@index([restaurantId, createdAt])
  @@index([customerId, createdAt])
  @@index([campaignId])
  @@map("message_logs")
}

model WhatsAppIntegration {
  id                 String                    @id @default(cuid())
  restaurantId       String                    @unique @map("restaurant_id")
  status             WhatsAppIntegrationStatus @default(pending)
  wabaId             String?                   @map("waba_id")
  businessAccountId  String?                   @map("business_account_id")
  phoneNumberId      String                    @unique @map("phone_number_id")
  displayPhoneNumber String                    @map("display_phone_number")
  accessTokenCipher  String                    @map("access_token_cipher") @db.Text
  tokenLastFour      String?                   @map("token_last_four")
  connectedAt        DateTime?                 @map("connected_at")
  lastWebhookAt      DateTime?                 @map("last_webhook_at")
  lastTemplateSyncAt DateTime?                 @map("last_template_sync_at")
  lastError          String?                   @map("last_error") @db.Text
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  restaurant    Restaurant                  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  templates     WhatsAppTemplate[]
  conversations WhatsAppConversation[]
  messages      WhatsAppMessage[]
  statusEvents  WhatsAppMessageStatusEvent[]

  @@index([restaurantId, status])
  @@index([phoneNumberId])
  @@map("whatsapp_integrations")
}

model WhatsAppTemplate {
  id            String                @id @default(cuid())
  restaurantId  String                @map("restaurant_id")
  integrationId String?               @map("integration_id")
  name          String
  label         String
  category      String
  language      String                @default("en")
  status        WhatsAppTemplateStatus @default(draft)
  body          String                @db.Text
  variables     Json?
  metaTemplateId String?              @map("meta_template_id")
  rejectionReason String?             @map("rejection_reason") @db.Text
  lastSyncedAt  DateTime?             @map("last_synced_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  restaurant  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  integration WhatsAppIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@unique([restaurantId, name, language])
  @@index([restaurantId, status])
  @@index([integrationId])
  @@map("whatsapp_templates")
}

model WhatsAppConversation {
  id            String   @id @default(cuid())
  restaurantId  String   @map("restaurant_id")
  integrationId String?  @map("integration_id")
  customerId    String?  @map("customer_id")
  customerPhone String   @map("customer_phone")
  customerName  String?  @map("customer_name")
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  unreadCount   Int      @default(0) @map("unread_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  restaurant  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  integration WhatsAppIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  customer    Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages    WhatsAppMessage[]

  @@unique([restaurantId, customerPhone])
  @@index([restaurantId, lastMessageAt])
  @@index([customerId, lastMessageAt])
  @@index([integrationId])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id                String                    @id @default(cuid())
  restaurantId      String                    @map("restaurant_id")
  integrationId     String?                   @map("integration_id")
  conversationId    String?                   @map("conversation_id")
  customerId        String?                   @map("customer_id")
  messageLogId      String?                   @unique @map("message_log_id")
  providerMessageId String?                   @unique @map("provider_message_id")
  direction         WhatsAppMessageDirection
  type              WhatsAppMessageType       @default(text)
  status            WhatsAppMessageStatus     @default(received)
  fromPhone         String?                   @map("from_phone")
  toPhone           String?                   @map("to_phone")
  body              String?                   @db.Text
  rawPayload        Json?                     @map("raw_payload")
  sentAt            DateTime?                 @map("sent_at")
  deliveredAt       DateTime?                 @map("delivered_at")
  readAt            DateTime?                 @map("read_at")
  failedAt          DateTime?                 @map("failed_at")
  createdAt         DateTime                  @default(now()) @map("created_at")

  restaurant   Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  integration  WhatsAppIntegration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  conversation WhatsAppConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customer     Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messageLog   MessageLog?           @relation(fields: [messageLogId], references: [id], onDelete: SetNull)
  statusEvents WhatsAppMessageStatusEvent[]

  @@index([restaurantId, createdAt])
  @@index([conversationId, createdAt])
  @@index([customerId, createdAt])
  @@index([integrationId])
  @@map("whatsapp_messages")
}

model WhatsAppMessageStatusEvent {
  id                String                @id @default(cuid())
  restaurantId      String                @map("restaurant_id")
  integrationId     String?               @map("integration_id")
  messageId         String?               @map("message_id")
  providerMessageId String                @map("provider_message_id")
  status            WhatsAppMessageStatus
  recipientPhone    String?               @map("recipient_phone")
  errorCode         String?               @map("error_code")
  errorMessage      String?               @map("error_message")
  rawPayload        Json?                 @map("raw_payload")
  occurredAt        DateTime              @map("occurred_at")
  createdAt         DateTime              @default(now()) @map("created_at")

  restaurant  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  integration WhatsAppIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  message     WhatsAppMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([restaurantId, occurredAt])
  @@index([providerMessageId, occurredAt])
  @@index([messageId])
  @@index([integrationId])
  @@map("whatsapp_message_status_events")
}

model RestaurantDomain {
  id                 String       @id @default(cuid())
  restaurantId       String       @unique @map("restaurant_id")
  hostname           String       @unique
  status             DomainStatus @default(pending)
  verificationTarget String       @map("verification_target")
  verifiedAt         DateTime?    @map("verified_at")
  lastCheckedAt      DateTime?    @map("last_checked_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status])
  @@map("restaurant_domains")
}

model RestaurantSlugAlias {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  slug         String   @unique
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("restaurant_slug_aliases")
}

model RestaurantShortLink {
  id           String   @id @default(cuid())
  restaurantId String   @unique @map("restaurant_id")
  code         String   @unique
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant                 @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  aliases    RestaurantShortLinkAlias[]
  clicks     RestaurantShortLinkClick[]

  @@map("restaurant_short_links")
}

model RestaurantShortLinkAlias {
  id          String   @id @default(cuid())
  shortLinkId String   @map("short_link_id")
  code        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")

  shortLink RestaurantShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, createdAt])
  @@map("restaurant_short_link_aliases")
}

model RestaurantShortLinkClick {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  shortLinkId  String   @map("short_link_id")
  code         String
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shortLink  RestaurantShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([shortLinkId, createdAt])
  @@map("restaurant_short_link_clicks")
}

model BadgeType {
  id             String          @id @default(cuid())
  key            String          @unique
  label          String
  icon           String?
  color          String          @default("#F2E2B9")
  textColor      String          @default("#7A5211") @map("text_color")
  category       String          @default("promotion")
  displayOrder   Int             @default(0) @map("display_order")
  menuItemBadges MenuItemBadge[]

  @@map("badge_types")
}

model MenuItemBadge {
  id         String   @id @default(cuid())
  menuItemId String   @map("menu_item_id")
  badgeId    String   @map("badge_id")
  createdAt  DateTime @default(now()) @map("created_at")

  menuItem MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  badge    BadgeType @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, badgeId])
  @@index([menuItemId])
  @@map("menu_item_badges")
}

model DietaryTag {
  id           String               @id @default(cuid())
  key          String               @unique
  label        String
  icon         String?
  category     String               @default("dietary")
  menuItemTags MenuItemDietaryTag[]

  @@map("dietary_tags")
}

model MenuItemDietaryTag {
  id         String @id @default(cuid())
  menuItemId String @map("menu_item_id")
  tagId      String @map("tag_id")
  source     String @default("manual")
  confidence Float?

  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tag      DietaryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, tagId])
  @@index([menuItemId])
  @@map("menu_item_dietary_tags")
}

model MenuAnalysis {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  analysisType String   @map("analysis_type")
  result       Json
  menuHash     String   @map("menu_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([restaurantId, analysisType])
  @@map("menu_analyses")
}

model SeoAnalysis {
  id              String    @id @default(cuid())
  restaurantId    String    @map("restaurant_id")
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status          SeoStatus @default(queued)
  inputsHash      String    @map("inputs_hash")
  overallScore    Int?      @map("overall_score")
  gbpScore        Int?      @map("gbp_score")
  onPageScore     Int?      @map("on_page_score")
  rankGridScore   Int?      @map("rank_grid_score")
  citationsScore  Int?      @map("citations_score")
  reviewsScore    Int?      @map("reviews_score")
  rawData         Json      @map("raw_data")
  scorecard       Json
  recommendations Json
  progress        Json?
  errorMessage    String?   @map("error_message")
  costUsd         Decimal?  @map("cost_usd") @db.Decimal(10, 4)
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  @@index([restaurantId, createdAt])
  @@index([inputsHash])
  @@map("seo_analyses")
}

model AuditLead {
  id             String       @id @default(cuid())
  phone          String
  email          String?
  restaurantName String       @map("restaurant_name")
  location       String
  ipHash         String       @map("ip_hash")
  userAgent      String?      @map("user_agent")
  source         String?
  reportId       String?      @map("report_id")
  report         AuditReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([phone])
  @@index([createdAt])
  @@map("audit_leads")
}

model AuditReport {
  id               String      @id @default(cuid())
  slug             String      @unique
  inputsHash       String      @map("inputs_hash")
  status           SeoStatus   @default(queued)
  restaurantName   String      @map("restaurant_name")
  location         String
  primaryCuisine   String?     @map("primary_cuisine")
  scorecard        Json?
  rawData          Json?       @map("raw_data")
  recommendations  Json?
  photoScores      Json?       @map("photo_scores")
  peerBenchmark    Json?       @map("peer_benchmark")
  executiveSummary String?     @map("executive_summary")
  errorMessage     String?     @map("error_message")
  costUsd          Decimal?    @map("cost_usd") @db.Decimal(10, 4)
  progress         Json?
  completedAt      DateTime?   @map("completed_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  leads            AuditLead[]

  @@index([inputsHash, status])
  @@index([createdAt])
  @@map("audit_reports")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  feature      String
  tokensIn     Int      @default(0) @map("tokens_in")
  tokensOut    Int      @default(0) @map("tokens_out")
  costUsd      Float    @default(0) @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([restaurantId, feature, createdAt])
  @@map("ai_usage_logs")
}

model GbpConnection {
  id           String              @id @default(cuid())
  restaurantId String              @unique @map("restaurant_id")
  status       GbpConnectionStatus @default(not_connected)
  gbpUrl       String?             @map("gbp_url")
  placeId      String?             @map("place_id")
  verifiedAt   DateTime?           @map("verified_at")
  connectedAt  DateTime?           @map("connected_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("gbp_connections")
}
