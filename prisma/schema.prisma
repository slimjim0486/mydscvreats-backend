generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  restaurant_owner
  admin
}

enum SubscriptionStatus {
  trial
  active
  paused
  cancelled
}

enum SubscriptionPlan {
  starter
  pro
}

enum DomainStatus {
  pending
  verifying
  active
  failed
}

enum GbpConnectionStatus {
  not_connected
  self_reported
  verified
}

enum PromotionType {
  discounted_item
  deal
  combo
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  fullName  String?  @map("full_name")
  role      UserRole @default(restaurant_owner)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurants Restaurant[]

  @@map("users")
}

model Restaurant {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  description        String?
  cuisineType        String?            @map("cuisine_type")
  themeKey           String?            @map("theme_key")
  location           String?
  address            String?
  phone              String?
  website            String?
  whatsappNumber     String?            @map("whatsapp_number")
  whatsappPrefill    String?            @map("whatsapp_prefill")
  logoUrl            String?            @map("logo_url")
  coverImageUrl      String?            @map("cover_image_url")
  isPublished        Boolean            @default(false) @map("is_published")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  ownerId            String             @map("owner_user_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id])
  menuSections MenuSection[]
  menuItems    MenuItem[]
  subscription Subscription?
  customDomain RestaurantDomain?
  shortLink    RestaurantShortLink?
  pageViews    PageView[]
  brandingClicks BrandingClick[]
  shortLinkClicks RestaurantShortLinkClick[]
  whatsappClicks WhatsAppClick[]
  menuItemLikes MenuItemLike[]
  slugAliases  RestaurantSlugAlias[]
  promotions     Promotion[]
  gbpConnection  GbpConnection?

  @@index([ownerId])
  @@map("restaurants")
}

model MenuSection {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  name         String
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([restaurantId, displayOrder])
  @@map("menu_sections")
}

model MenuItem {
  id                  String   @id @default(cuid())
  sectionId           String   @map("section_id")
  restaurantId        String   @map("restaurant_id")
  name                String
  description         String?
  aiNotes             String?  @map("ai_notes")
  price               Decimal  @db.Decimal(10, 2)
  currency            String   @default("AED")
  imageUrl            String?  @map("image_url")
  imageStatus         String   @default("none") @map("image_status")
  isAvailable         Boolean  @default(true) @map("is_available")
  displayOrder        Int      @default(0) @map("display_order")
  aiDescriptionStatus String?  @map("ai_description_status")
  originalDescription String?  @map("original_description")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  section     MenuSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  restaurant  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  images      MenuItemImage[]
  dietaryTags MenuItemDietaryTag[]
  badges      MenuItemBadge[]
  promotionItems PromotionItem[]
  whatsappClicks WhatsAppClick[]
  likes       MenuItemLike[]

  @@index([restaurantId, displayOrder])
  @@index([sectionId, displayOrder])
  @@map("menu_items")
}

model MenuItemImage {
  id             String   @id @default(cuid())
  menuItemId     String   @map("menu_item_id")
  slot           Int
  imageUrl       String?  @map("image_url")
  imageStatus    String   @default("none") @map("image_status")
  promptModifier String?  @map("prompt_modifier")
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, slot])
  @@index([menuItemId, createdAt])
  @@map("menu_item_images")
}

model Promotion {
  id          String        @id @default(cuid())
  restaurantId String       @map("restaurant_id")
  type        PromotionType
  title       String
  subtitle    String?
  description String?
  badgeLabel  String?       @map("badge_label")
  terms       String?
  promoPrice  Decimal?      @map("promo_price") @db.Decimal(10, 2)
  startsAt    DateTime?     @map("starts_at")
  endsAt      DateTime?     @map("ends_at")
  isActive    Boolean       @default(true) @map("is_active")
  isFeatured  Boolean       @default(true) @map("is_featured")
  displayOrder Int          @default(0) @map("display_order")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      PromotionItem[]
  whatsappClicks WhatsAppClick[]

  @@index([restaurantId, displayOrder])
  @@index([restaurantId, isActive, startsAt, endsAt])
  @@map("promotions")
}

model PromotionItem {
  id          String   @id @default(cuid())
  promotionId String   @map("promotion_id")
  menuItemId  String   @map("menu_item_id")
  role        String   @default("included")
  displayOrder Int     @default(0) @map("display_order")
  createdAt   DateTime @default(now()) @map("created_at")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([promotionId, menuItemId])
  @@index([menuItemId, displayOrder])
  @@index([promotionId, displayOrder])
  @@map("promotion_items")
}

model Subscription {
  id                   String             @id @default(cuid())
  restaurantId         String             @unique @map("restaurant_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

model PageView {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  path         String
  hostname     String?
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("page_views")
}

model BrandingClick {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  path         String?
  referrer     String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("branding_clicks")
}

model MenuItemLike {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  menuItemId   String   @map("menu_item_id")
  path         String?
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
  @@map("menu_item_likes")
}

model WhatsAppClick {
  id          String    @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  menuItemId  String?   @map("menu_item_id")
  promotionId String?   @map("promotion_id")
  source      String
  path        String?
  campaign    String?
  referrer    String?
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  promotion  Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
  @@index([promotionId, createdAt])
  @@map("whatsapp_clicks")
}

model RestaurantDomain {
  id                 String       @id @default(cuid())
  restaurantId       String       @unique @map("restaurant_id")
  hostname           String       @unique
  status             DomainStatus @default(pending)
  verificationTarget String       @map("verification_target")
  verifiedAt         DateTime?    @map("verified_at")
  lastCheckedAt      DateTime?    @map("last_checked_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status])
  @@map("restaurant_domains")
}

model RestaurantSlugAlias {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  slug         String   @unique
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("restaurant_slug_aliases")
}

model RestaurantShortLink {
  id           String   @id @default(cuid())
  restaurantId String   @unique @map("restaurant_id")
  code         String   @unique
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant                     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  aliases    RestaurantShortLinkAlias[]
  clicks     RestaurantShortLinkClick[]

  @@map("restaurant_short_links")
}

model RestaurantShortLinkAlias {
  id          String   @id @default(cuid())
  shortLinkId String   @map("short_link_id")
  code        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")

  shortLink RestaurantShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, createdAt])
  @@map("restaurant_short_link_aliases")
}

model RestaurantShortLinkClick {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  shortLinkId  String   @map("short_link_id")
  code         String
  userAgent    String?  @map("user_agent")
  referrer     String?
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shortLink  RestaurantShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([shortLinkId, createdAt])
  @@map("restaurant_short_link_clicks")
}

model BadgeType {
  id       String          @id @default(cuid())
  key      String          @unique
  label    String
  icon     String?
  color    String          @default("#F2E2B9")
  textColor String         @default("#7A5211") @map("text_color")
  category String          @default("promotion")
  displayOrder Int         @default(0) @map("display_order")
  menuItemBadges MenuItemBadge[]

  @@map("badge_types")
}

model MenuItemBadge {
  id         String   @id @default(cuid())
  menuItemId String   @map("menu_item_id")
  badgeId    String   @map("badge_id")
  createdAt  DateTime @default(now()) @map("created_at")

  menuItem MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  badge    BadgeType @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, badgeId])
  @@index([menuItemId])
  @@map("menu_item_badges")
}

model DietaryTag {
  id           String               @id @default(cuid())
  key          String               @unique
  label        String
  icon         String?
  category     String               @default("dietary")
  menuItemTags MenuItemDietaryTag[]

  @@map("dietary_tags")
}

model MenuItemDietaryTag {
  id         String @id @default(cuid())
  menuItemId String @map("menu_item_id")
  tagId      String @map("tag_id")
  source     String @default("manual")
  confidence Float?

  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tag      DietaryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, tagId])
  @@index([menuItemId])
  @@map("menu_item_dietary_tags")
}

model MenuAnalysis {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  analysisType String   @map("analysis_type")
  result       Json
  menuHash     String   @map("menu_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([restaurantId, analysisType])
  @@map("menu_analyses")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  feature      String
  tokensIn     Int      @default(0) @map("tokens_in")
  tokensOut    Int      @default(0) @map("tokens_out")
  costUsd      Float    @default(0) @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([restaurantId, feature, createdAt])
  @@map("ai_usage_logs")
}

model GbpConnection {
  id            String              @id @default(cuid())
  restaurantId  String              @unique @map("restaurant_id")
  status        GbpConnectionStatus @default(not_connected)
  gbpUrl        String?             @map("gbp_url")
  placeId       String?             @map("place_id")
  verifiedAt    DateTime?           @map("verified_at")
  connectedAt   DateTime?           @map("connected_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("gbp_connections")
}
