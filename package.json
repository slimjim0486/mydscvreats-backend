{
  "name": "bustan-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "worker": "tsx src/queue/worker.ts",
    "smoke:meta-callbacks": "tsx scripts/smoke-test-meta-callbacks.ts",
    "admin:promote": "tsx scripts/promote-admin.ts",
    "sabt-pack:trigger": "tsx scripts/sabt-pack-trigger.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@clerk/backend": "^1.27.1",
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.53.1",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^16.4.7",
    "hono": "^4.6.15",
    "jszip": "^3.10.1",
    "pg-boss": "^10.1.6",
    "qrcode": "^1.5.4",
    "resend": "^4.1.1",
    "sharp": "^0.34.5",
    "stripe": "^17.5.0",
    "svix": "^1.93.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^6.1.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
