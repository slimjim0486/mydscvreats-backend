GEMINI_API_KEY=
# Compatibility alias if you already use this older name somewhere else.
GOOGLE_API_KEY=
GOOGLE_IMAGE_API_URL=https://generativelanguage.googleapis.com/v1beta/interactions
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
GOOGLE_IMAGE_ALLOW_FALLBACK=false
GOOGLE_IMAGE_FALLBACK_MODEL=gemini-2.5-flash-image
# Legacy alias still accepted if your key is already stored under the old name.
NANOBANANA_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mydscvr-eats
R2_PUBLIC_URL=https://images.mydscvr.ai
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@mydscvr.ai
FRONTEND_APP_URL=http://localhost:3000
# Optional override for the DNS target restaurant subdomains should CNAME to.
# In production this usually matches the frontend hostname.
CUSTOM_DOMAIN_CNAME_TARGET=mydscvr.ai
